{
  "name": "pbcomponents-monorepo",
  "version": "0.0.0",
  "description": "UI component library for React with Typescript and Tailwind",
  "main": "index.js",
  "private": true,
  "workspaces": [
    "./workspaces/*"
  ],
  "engines": {
    "node": ">=22.x"
  },
  "scripts": {
    "dev:components": "npm run --workspace=@prosazhin/pbcomponents dev",
    "dev:storybook": "npm run --workspace=pbcomponents-storybook dev",
    "dev": "npm-run-all -p dev:*",
    "build:components": "npm run --workspace=@prosazhin/pbcomponents build",
    "build:storybook": "npm run --workspace=pbcomponents-storybook build",
    "build": "npm-run-all -p build:*",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,md,mdx,json}\"",
    "install-force": "npm install --force",
    "clean": "npm run clean:build --workspaces --if-present && npm run clean:modules --workspaces --if-present && rm package-lock.json && rimraf ./node_modules",
    "prepare": "npx simple-git-hooks"
  },
  "author": "Evgenii Sazhin <prosazhin@gmail.com> (https://prosazhin.ru)",
  "license": "MIT",
  "simple-git-hooks": {
    "pre-commit": "npx --no-install lint-staged --concurrent false",
    "pre-push": "npm run format",
    "commit-msg": "npx --no-install commitlint --edit ${1}"
  },
  "lint-staged": {
    "*": "npm run format"
  },
  "prettier": {
    "bracketSpacing": true,
    "semi": true,
    "useTabs": false,
    "trailingComma": "all",
    "printWidth": 140,
    "tabWidth": 2,
    "jsxSingleQuote": true,
    "singleQuote": true,
    "quoteProps": "as-needed",
    "arrowParens": "always",
    "endOfLine": "lf",
    "organizeImportsSkipDestructiveCodeActions": true,
    "plugins": [
      "prettier-plugin-organize-imports",
      "prettier-plugin-tailwindcss"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "dependencies": {
    "@prosazhin/pbcomponents": "*"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "lint-staged": "^16.3.2",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rimraf": "^6.1.3",
    "simple-git-hooks": "^2.13.1",
    "storybook": "^10.2.19"
  }
}
